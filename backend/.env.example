# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/perigee

# LLM Provider (anthropic | openai_compatible)
LLM_PROVIDER=anthropic
LLM_VISION_PROVIDER=
LLM_MODEL=
LLM_VISION_MODEL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
LLM_MAX_CONCURRENCY=4
LLM_TOOL_RESULT_MAX_CHARS=12000

# Anthropic (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

# OpenAI-compatible (required when LLM_PROVIDER=openai_compatible)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Security
SECRET_KEY=your-256-bit-secret-key-change-in-production
ENCRYPTION_MASTER_KEY=your-32-byte-encryption-key-here

# JWT Configuration
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth (Google)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:5173

# Debug mode
DEBUG=false

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_pro_plan_price_id
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_plan_price_id

# Resend Email (transactional emails - email verification, password reset)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@perigee.ai

# Admin Seeding (for scripts/seed_admin.py)
ADMIN_PASSWORD=your-secure-admin-password

# Connector Credentials for Admin Account (optional - set the ones you have)
SITEUSA_USERNAME=
SITEUSA_PASSWORD=
PLACER_USERNAME=
PLACER_PASSWORD=
COSTAR_USERNAME=
COSTAR_PASSWORD=
