# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/spacefit

# Security
SECRET_KEY=your-256-bit-secret-key-change-in-production
ENCRYPTION_MASTER_KEY=your-32-byte-encryption-key-here

# JWT Configuration
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth (Google)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:5173

# Debug mode
DEBUG=false

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_pro_plan_price_id
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_plan_price_id

# Admin Seeding (for scripts/seed_admin.py)
ADMIN_PASSWORD=your-secure-admin-password

# Connector Credentials for Admin Account (optional - set the ones you have)
SITEUSA_USERNAME=
SITEUSA_PASSWORD=
PLACER_USERNAME=
PLACER_PASSWORD=
COSTAR_USERNAME=
COSTAR_PASSWORD=
